<div>
   <% if @show_alert %>
    <div class="margin-bottom-4 usa-alert usa-alert--<%= @alert_type || 'error' %>">
      <div class="usa-alert__body">
        <h1 class="usa-alert__heading"><%= t(key=@status, csp_display_name: @csp_display_name) %></h1>
        <p class="usa-alert__text">
          <%=raw t(key=@text, org_name: @org_name, ao_full_name: @ao_full_name, ao_email: @ao_email) %>
        </p>
      </div>
    </div>
   <% else %>
    <h1><%= t(key=@status, csp_display_name: @csp_display_name) %></h1>
    <div>
      <p>
        <%=raw t(key=@text, org_name: @org_name, ao_full_name: @ao_full_name, ao_email: @ao_email, csp_display_name: @csp_display_name) %>
      </p>
    </div>   
   <% end %>
  
  <% 'have to put the case statement here, as do not have route helper in ViewComponent'
    case(@reason)
      when :ao_expired %>
        <%= render Core::Button::ButtonComponent.new(label: "Request new link",
            disabled: @invitation&.renewed?,
            destination: renew_organization_invitation_path(@invitation.provider_organization, @invitation)) %>
      <% when :ao_accepted %>
        <%= link_to sign_in_path, class: 'usa-button', data: { turbo: false } do %>
          Sign in with <span class="login-button__logo"><%= @csp_display_name %></span>
        <% end %>
      <% when :cd_accepted %>
        <%= link_to 'Go to DPC home', root_url, class: 'usa-button margin-right-0' %>
      <% when :pii_mismatch %>
        <%= render Core::Button::ButtonComponent.new(label: "Sign out of #{@csp_display_name}",
            destination: csp_logout_path(invitation_id: @invitation.id),
            method: :delete) %>
      <% when :email_mismatch %>
        <%= render Core::Button::ButtonComponent.new(label: "Sign out of #{@csp_display_name}",
            destination: csp_logout_path(invitation_id: @invitation.id),
            method: :delete) %>
      <% when :no_account %>
        <%= render Core::Button::ButtonComponent.new(label: "Sign out of #{@csp_display_name}",
            destination: csp_logout_path,
            method: :delete) %>
      <% when /signin_cancel/ %>
        <%= link_to 'Back to portal home', sign_in_path, class: 'usa-button usa-button--outline', data: { turbo: false }%>
      <% when /signin_fail/ %>
        <%= link_to 'Back to portal home', sign_in_path, class: 'usa-button usa-button--outline', data: { turbo: false }%>
    <% end %>
</div>
