<%# <%# This is hidden from sr's on purpose, since its redundant when used with nearby content. %>
<%# However, USWDS uses table captions for aria-live regions on sortable tables %>
<caption aria-hidden="true" hidden><%= caption %></caption>
<thead>
  <tr>
    <% columns.each do |column| %>
      <% if column.sortable %>
        <th data-sortable scope="col" role="columnheader" aria-sort="descending">
            <%= column.label %>
        </th>
      <% else %>
        <th scope="col" role="columnheader">
            <%= column.label %>
        </th>
      <% end %>
    <% end %>
  </tr>
</thead>
