DD_AGENT_HOST=datadog-agent
DD_ENV=local-dev
DD_VERSION=0.4.0-SNAPSHOT
DD_PROFILING_ENABLED=true
DD_TRACE_OTEL_ENABLED=true
DD_INSTRUMENTATION_TELEMETRY_ENABLED=false
DD_TRACE_SAMPLING_RULES='[
  {"resource":"GET /healthcheck","sample_rate":0.0},
  {"resource":"GET /health_check","sample_rate":0.0},
  {"resource":"GET /v1/version","sample_rate":0.0},
  {"resource":"GET /v1/fhir/metadata","sample_rate":0.0},
  {"resource":"GET /api/v1/version","sample_rate":0.0},
  {"resource":"GET /ping","sample_rate":0.0}
]'
